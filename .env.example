LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=****  # generate with: bun -e "console.log(Buffer.from(crypto.getRandomValues(new Uint8Array(32))).toString('base64'))"
DEEPGRAM_API_KEY=****

# LLM backend: 'relay' (default) routes voice LLM through the relay via data channel.
# GANGLIA_TYPE=relay

# ACP backend (deprecated) — spawns an OpenClaw subprocess directly in the voice-agent.
# Only needed if GANGLIA_TYPE=acp.
# ACP_COMMAND=openclaw
# ACP_ARGS=acp
# ACP_PROMPT_TIMEOUT_MS=120000

# Nanoclaw backend (single-user, local)
# GANGLIA_TYPE=nanoclaw
# NANOCLAW_URL=http://localhost:18789
# NANOCLAW_CHANNEL_PREFIX=lk

# TTS provider: 'elevenlabs' | 'google' | 'piper' (default)
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=****
ELEVENLABS_VOICE_ID=your-voice-id
GOOGLE_API_KEY=****
GOOGLE_TTS_VOICE=Kore
