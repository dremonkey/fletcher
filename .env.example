LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=****  # generate with: bun -e "console.log(Buffer.from(crypto.getRandomValues(new Uint8Array(32))).toString('base64'))"
DEEPGRAM_API_KEY=****

# LLM backend: 'acp' (default) or 'nanoclaw'
# GANGLIA_TYPE=acp

# ACP backend (default) — spawns an OpenClaw subprocess via JSON-RPC 2.0 over stdio.
# The subprocess handles its own authentication; no API key needed from the voice agent.
# ACP_COMMAND=openclaw          # command to spawn (default: openclaw)
# ACP_ARGS=acp                  # comma-separated args (default: acp)
# ACP_PROMPT_TIMEOUT_MS=120000  # prompt timeout in ms (default: 120000)

# Nanoclaw backend (single-user, local)
# GANGLIA_TYPE=nanoclaw
# NANOCLAW_URL=http://localhost:18789
# NANOCLAW_CHANNEL_PREFIX=lk

# TTS provider: 'elevenlabs' | 'google' | 'piper' (default)
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=****
ELEVENLABS_VOICE_ID=your-voice-id
GOOGLE_API_KEY=****
GOOGLE_TTS_VOICE=Kore
