# LiveKit connection
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ACP backend (subprocess spawned per room)
# Options:
#   openclaw (default) — OpenClaw gateway. Requires ACP_ARGS=acp.
#   claude-agent-acp   — Claude Agent ACP adapter (@zed-industries/claude-agent-acp).
#                        Auth: CLAUDE_CODE_OAUTH_TOKEN or ANTHROPIC_API_KEY. No ACP_ARGS needed.
ACP_COMMAND=openclaw
ACP_ARGS=acp

# Claude Code authentication (required when ACP_COMMAND=claude-agent-acp)
# Uses CLAUDE_CODE_OAUTH_TOKEN (from ~/.zshrc) or ANTHROPIC_API_KEY.
# ANTHROPIC_API_KEY=sk-ant-...

# HTTP server
RELAY_HTTP_PORT=7890

# Idle room timeout in ms (default: 30 minutes)
RELAY_IDLE_TIMEOUT_MS=1800000

# Logging
LOG_LEVEL=debug         # trace | debug | info | warn | error | fatal
                        # debug: shows message traffic (mobile ↔ ACP), webhook events
NODE_ENV=development    # "production" for JSON output, otherwise pretty-printed
