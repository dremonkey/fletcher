LIVEKIT_URL=ws://192.168.1.100:7880
LIVEKIT_URL_TAILSCALE=ws://100.x.x.x:7880
LIVEKIT_URL_EMULATOR=ws://10.0.2.2:7880

# Token endpoint port — must match TOKEN_SERVER_PORT in docker-compose.yml
TOKEN_SERVER_PORT=7882

# IMPORTANT: Must match room.departure_timeout in livekit.yaml (currently 120s).
# The client derives session staleness and reconnect budget from this value.
# If they drift, the client may rejoin dead rooms or create new rooms too early.
DEPARTURE_TIMEOUT_S=120

# Display name for the AI agent in the chat UI
AGENT_NAME=Fletcher

LIVEKIT_TOKEN=
